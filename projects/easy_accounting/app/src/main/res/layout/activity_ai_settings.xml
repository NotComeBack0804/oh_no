<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.ai.AiSettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_panel"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择你的 AI 伴侣"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="聊天优先，记账其次。你可以直接选内置官方通道，也可以接入自己的 OpenAI / Claude / 兼容接口。"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_soft_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="模型通道"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProviderHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_ai_context_banner"
                    android:padding="12dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    tools:text="使用内置官方 GPT-5.4 通道，已封装好接口信息，页面只展示模型名称。" />

                <RadioGroup
                    android:id="@+id/rgProvider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_provider_preset_gpt54"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="GPT-5.4（内置官方通道）" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_provider_builtin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="内置智脑（本地语义）" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_provider_openai"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="自定义 OpenAI" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_provider_anthropic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="自定义 Claude / Anthropic" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_provider_compatible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="自定义兼容 OpenAI 协议" />
                </RadioGroup>

                <LinearLayout
                    android:id="@+id/groupPresetFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_ai_context_banner"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前预设模型"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPresetModelValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="GPT-5.4"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="接口地址、模型名和密钥已在应用内封装，不对用户展示。"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/groupRemoteFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEndpoint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Base URL / Endpoint"
                            android:inputType="textUri" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etModel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="模型名称"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="API Key"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTest"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="测试连接"
                        app:icon="@drawable/ic_tune"
                        app:iconTint="?attr/colorPrimary"
                        app:strokeColor="?attr/colorPrimary" />

                    <ProgressBar
                        android:id="@+id/progressTesting"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTestResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_ai_context_banner"
                    android:padding="12dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:visibility="gone"
                    tools:text="GPT-5.4 连接失败（HTTP 401）：Invalid API key" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_soft_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="角色人设"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="AI 会先像真人一样陪你聊天，再在合适的时候顺手帮你把账记下来。"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <RadioGroup
                    android:id="@+id/rgPersona"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_persona_boyfriend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="温柔男友" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_persona_girlfriend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="元气女友" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_persona_butler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="高冷管家" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rb_persona_friend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="毒舌损友" />
                </RadioGroup>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCompanionName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="伴侣昵称"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCustomPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:hint="自定义角色补充设定（可选）"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minLines="4" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:text="保存 AI 设置"
                app:icon="@drawable/ic_check"
                app:iconTint="@android:color/white" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
