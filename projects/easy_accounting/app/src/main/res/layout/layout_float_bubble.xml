<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_float_bubble"
    android:elevation="10dp"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle">

            <ImageView
                android:id="@+id/iv_source_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="支付来源图标"
                android:src="@drawable/ic_alipay" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_bubble_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="¥0.00"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="#D92D20"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_bubble_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="支付来源"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text="·"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tv_bubble_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_category_food"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="餐饮"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_food"
            app:tint="#F79009" />

        <ImageButton
            android:id="@+id/btn_category_transport"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="交通"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_transport"
            app:tint="#1570EF" />

        <ImageButton
            android:id="@+id/btn_category_shopping"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="购物"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_shopping"
            app:tint="#EE46BC" />

        <ImageButton
            android:id="@+id/btn_category_other"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="其他"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_other"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_ignore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="忽略"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/btn_confirm"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_confirm_button"
            android:contentDescription="确认"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white" />
    </LinearLayout>
</LinearLayout>
